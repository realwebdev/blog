    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Launch Serve",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "args": ["serve"]
        },
        {
            "name": "Launch Migrate Up",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "args": ["migrate", "up"]
        },
        {
            "name": "Launch Seed",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/main.go",
            "args": ["seed"]
        }
    ]
}